{
  "$schema": "https://mintlify.com/docs.json",
  "name": "imagemin CLI",
  "theme": "mint",
  "colors": {
    "primary": "#4CAF50",
    "light": "#81C784",
    "dark": "#2E7D32"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/imagemin/imagemin-cli"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/imagemin/imagemin-cli"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation"]
          },
          {
            "group": "Usage",
            "pages": ["usage/basic-usage", "usage/stdin-stdout", "usage/glob-patterns"]
          },
          {
            "group": "Plugins",
            "pages": ["plugins/overview", "plugins/default-plugins", "plugins/custom-plugins", "plugins/plugin-options"]
          },
          {
            "group": "Reference",
            "pages": ["reference/cli-flags", "reference/troubleshooting"]
          }
        ]
      }
    ]
  }
}
